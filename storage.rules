rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Public property listing images (Read allowed globally, write allowed for listing roles)
    match /listings/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'broker', 'listing_agent'];
    }
    
    // 2. Private deal vault documents (Default-deny direct reads; mediated by Cloud Functions)
    match /deals/{dealId}/{allPaths=**} {
      allow read: if false;
      allow write: if request.auth != null;
    }
  }
}
