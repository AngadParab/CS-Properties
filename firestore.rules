rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function role() {
      return isAuthenticated() && 'role' in request.auth.token ? request.auth.token.role : null;
    }

    function isAdminOrBroker() {
      return role() in ['admin', 'broker'];
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.admin == true || role() == 'admin');
    }

    function isOwner(agentIdField) {
      return isAuthenticated() && resource != null && 'data' in resource && agentIdField in resource.data && request.auth.uid == resource.data[agentIdField];
    }

    // Schema Validation Helpers
    function isValidProperty(data) {
      return data.address is string && data.address.size() > 0
          && data.city is string && data.city.size() > 0
          && data.bedrooms is int && data.bedrooms >= 0
          && data.bathrooms is int && data.bathrooms >= 0
          && data.squareFootage is int && data.squareFootage > 0
          && data.assetClass is string && data.assetClass.size() > 0
          && data.subtype is string && data.subtype.size() > 0
          && data.description is string
          && (data.ownerContactId == null || data.ownerContactId is string)
          && (data.hoaFee == null || data.hoaFee is int || data.hoaFee is string)
          && data.amenities is list
          && data.createdAt is string;
    }

    function isValidListing(data) {
      return data.propertyId is string && data.propertyId.size() > 0
          && (data.listingAgentId == null || data.listingAgentId is string)
          && data.askingPrice is int && data.askingPrice >= 0
          && data.status is string && data.status.size() > 0
          && data.webDisplay is bool
          && data.propertyAddress is string && data.propertyAddress.size() > 0
          && data.propertyCity is string && data.propertyCity.size() > 0
          && data.images is list
          && data.notes is string
          && data.createdAt is string
          && data.updatedAt is string;
    }

    // Agents collection
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if role() == 'admin';
    }

    // Contacts collection
    match /contacts/{contactId} {
      allow read: if isAdminOrBroker() || (role() == 'sales_agent' && isOwner('assignedAgentId'));
      allow write: if isAdminOrBroker() || (role() == 'sales_agent' && isOwner('assignedAgentId'));
    }

    // Properties collection
    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidProperty(request.resource.data);
    }

    // Listings collection
    match /listings/{listingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidListing(request.resource.data);
    }

    // Deals collection
    match /deals/{dealId} {
      allow read: if isAdminOrBroker() || (role() == 'sales_agent' && isOwner('assignedAgentId'));
      allow write: if isAdminOrBroker() || (role() == 'sales_agent' && isOwner('assignedAgentId'));
    }

    // Commissions collection (Write only via Admin SDK)
    match /commissions/{commissionId} {
      allow read: if isAdminOrBroker();
      allow write: if false;
    }

    // Activity Log collection
    match /activityLog/{entryId} {
      allow read: if isAdminOrBroker() || (role() == 'sales_agent' && isOwner('createdBy'));
      allow write: if isAdminOrBroker() || role() == 'sales_agent';
    }

    // Documents collection (Direct access denied; mediated by getDocumentUrl Cloud Function)
    match /documents/{documentId} {
      allow read, write: if false;
    }

    // Document Access Log collection (Direct access denied)
    match /documentAccessLog/{entryId} {
      allow read, write: if false;
    }

    // Rate limits (Direct access denied)
    match /rateLimits/{ip} {
      allow read, write: if false;
    }

    // Broker Escalations collection
    match /brokerEscalations/{escalationId} {
      allow read: if isAdminOrBroker();
      allow write: if false;
    }
  }
}
